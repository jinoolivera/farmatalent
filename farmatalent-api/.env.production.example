APP_NAME=FarmaTalent
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://farmatalent.devicesperu.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=farmatalent
DB_USERNAME=farmatalent
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.farmatalent.devicesperu.com
QUEUE_CONNECTION=database

FRONTEND_URL=https://farmatalent.devicesperu.com
SANCTUM_STATEFUL_DOMAINS=farmatalent.devicesperu.com

MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=CHANGE_ME_RESEND_API_KEY
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@farmatalent.pe
MAIL_FROM_NAME=FarmaTalent
